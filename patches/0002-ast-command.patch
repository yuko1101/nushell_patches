@@ -0,0 +1,334 @@
+use std::collections::HashMap;
+
+use nu_engine::command_prelude::*;
+use nu_parser::parse;
+use nu_protocol::{
+    Id, LabeledError,
+    ast::{self, Argument, Block, Expr, Expression},
+    engine::StateWorkingSet,
+    record,
+};
+
+#[derive(Clone)]
+pub struct AstCommand;
+
+impl Command for AstCommand {
+    fn name(&self) -> &str {
+        "ast command"
+    }
+
+    fn description(&self) -> &str {
+        "Print the abstract syntax tree (ast) for the last command in a pipeline string."
+    }
+
+    fn signature(&self) -> Signature {
+        Signature::build("ast command")
+            .input_output_type(Type::Nothing, Type::record())
+            .required(
+                "buffer",
+                SyntaxShape::String,
+                "The buffer to print the ast for.",
+            )
+            .allow_variants_without_examples(true)
+            .category(Category::Debug)
+    }
+
+    fn examples(&'_ self) -> Vec<Example<'_>> {
+        vec![
+            Example {
+                description: "Print the ast from a simple buffer.",
+                example: "ast command 'glob *.rs -Dd 2'",
+                result: Some(Value::test_record(record! {
+                    "command" => Value::test_string("glob"),
+                    "args" => Value::test_record(record! {
+                        "positional" => Value::test_list(vec![
+                            Value::test_record(record! {
+                                "value" => Value::test_string("*.rs"),
+                                "type" => Value::test_string("string"),
+                                "kind" => Value::test_string("string"),
+                            }),
+                        ]),
+                        "named" => Value::test_record(record! {
+                            "no-dir" => Value::test_nothing(),
+                            "depth" => Value::test_record(record! {
+                                "value" => Value::test_int(2),
+                                "type" => Value::test_string("int"),
+                                "kind" => Value::test_string("number"),
+                            }),
+                        }),
+                    }),
+                    "errors" => Value::test_nothing(),
+                })),
+            },
+            Example {
+                description: "Print the ast from a buffer with an unterminated subexpression.",
+                example: "ast command 'cp (input'",
+                result: Some(Value::test_record(record! {
+                    "command" => Value::test_string("input"),
+                    "args" => Value::test_record(record! {
+                        "positional" => Value::test_list(vec![]),
+                        "named" => Value::test_record(record! {}),
+                    }),
+                    "errors" => Value::test_string("Unexpected end of code."),
+                })),
+            },
+            Example {
+                description: "Print the ast from a buffer with an unterminated block.",
+                example: "ast command 'do { ls -a'",
+                result: Some(Value::test_record(record! {
+                    "command" => Value::test_string("ls"),
+                    "args" => Value::test_record(record! {
+                        "positional" => Value::test_list(vec![]),
+                        "named" => Value::test_record(record! {
+                            "all" => Value::test_nothing(),
+                        }),
+                    }),
+                    "errors" => Value::test_string("Unexpected end of code."),
+                })),
+            },
+        ]
+    }
+
+    fn run(
+        &self,
+        engine_state: &EngineState,
+        stack: &mut Stack,
+        call: &Call,
+        _input: PipelineData,
+    ) -> Result<PipelineData, ShellError> {
+        let pipeline: Spanned<String> = call.req(engine_state, stack, 0)?;
+
+        let mut working_set = StateWorkingSet::new(engine_state);
+        let parsed_block = parse(&mut working_set, None, pipeline.item.as_bytes(), false);
+        let error_output = working_set.parse_errors.first();
+
+        let cursor = parsed_block
+            .span
+            .ok_or_else(|| {
+                ShellError::LabeledError(Box::new(
+                    LabeledError::new("No span found for the pipeline")
+                        .with_label("Expected a valid pipeline", pipeline.span),
+                ))
+            })?
+            .end
+            - 1;
+        let target_call =
+            find_target_call(&parsed_block, &working_set, cursor).ok_or_else(|| {
+                ShellError::LabeledError(Box::new(
+                    LabeledError::new("No command call found in the pipeline")
+                        .with_label("Expected a command", pipeline.span),
+                ))
+            })?;
+
+        let command_name = engine_state
+            .get_decl(target_call.decl_id)
+            .name()
+            .to_string();
+
+        let mut positional_args = Vec::new();
+        let mut named_args = HashMap::new();
+
+        for arg in &target_call.arguments {
+            match arg {
+                Argument::Positional(expr) => {
+                    positional_args.push(expr);
+                }
+                Argument::Named((name, _, expr)) => {
+                    named_args.insert(name.item.clone(), expr);
+                }
+                Argument::Unknown(expr) => {
+                    positional_args.push(expr);
+                }
+                Argument::Spread(expr) => {
+                    positional_args.push(expr);
+                }
+            }
+        }
+
+        let positional_args: Vec<Value> = positional_args
+            .into_iter()
+            .map(|e| Value::record(parse_expr(&working_set, e, pipeline.span), pipeline.span))
+            .collect();
+
+        let named_args: Record = named_args
+            .into_iter()
+            .filter_map(|(k, v)| {
+                // keys can be empty in some cases (e.g. missing flag argument; "reduce -f")
+                if k.is_empty() {
+                    return None;
+                }
+                let Some(v) = v else {
+                    return Some((k, Value::nothing(pipeline.span)));
+                };
+                let record = parse_expr(&working_set, v, pipeline.span);
+                Some((k, Value::record(record, pipeline.span)))
+            })
+            .fold(Record::new(), |mut acc, (k, v)| {
+                acc.insert(k, v);
+                acc
+            });
+
+        let parsed = record! {
+            "command" => Value::string(command_name, call.head),
+            "args" => Value::record(record! {
+                "positional" => Value::list(
+                    positional_args,
+                    pipeline.span,
+                ),
+                "named" => Value::record(named_args, pipeline.span),
+            }, pipeline.span),
+            "errors" => match error_output {
+                Some(err) => Value::string(err.to_string(), call.head),
+                None => Value::nothing(call.head),
+            },
+        };
+
+        Ok(PipelineData::Value(Value::record(parsed, call.head), None))
+    }
+}
+
+fn find_target_call<'a>(
+    parsed_block: &'a Block,
+    working_set: &'a StateWorkingSet,
+    cursor: usize,
+) -> Option<&'a Box<ast::Call>> {
+    let last_element = parsed_block
+        .pipelines
+        .last()
+        .and_then(|p| p.elements.last());
+
+    let Some(last_element) = last_element else {
+        return None;
+    };
+
+    // TODO: also support Expr::ExternalCall
+    let Expr::Call(call) = &last_element.expr.expr else {
+        return None;
+    };
+    if !is_cursor_in_call(call, cursor, working_set) {
+        return None;
+    }
+
+    find_subcall(call, working_set, cursor).or(Some(call))
+}
+
+fn find_subcall<'a>(
+    call: &'a ast::Call,
+    working_set: &'a StateWorkingSet,
+    cursor: usize,
+) -> Option<&'a Box<ast::Call>> {
+    let Some(last_arg) = call.arguments.iter().last() else {
+        return None;
+    };
+
+    let expr = match last_arg {
+        Argument::Positional(expr)
+        | Argument::Named((_, _, Some(expr)))
+        | Argument::Unknown(expr)
+        | Argument::Spread(expr) => expr,
+        _ => {
+            return None;
+        }
+    };
+
+    let Some(inner_block) = find_inner_block(expr, working_set, cursor) else {
+        return None;
+    };
+
+    let inner_block = working_set.get_block(inner_block.clone());
+    find_target_call(inner_block, working_set, cursor)
+}
+
+fn find_inner_block<'a>(
+    expr: &'a Expression,
+    working_set: &'a StateWorkingSet,
+    cursor: usize,
+) -> Option<&'a Id<nu_protocol::marker::Block>> {
+    // TODO: support more expressions
+    match &expr.expr {
+        Expr::Subexpression(sub_expr) => Some(sub_expr),
+        Expr::FullCellPath(expr) => find_inner_block(&expr.head, working_set, cursor),
+        Expr::StringInterpolation(expr_vec) => expr_vec
+            .iter()
+            .last()
+            .and_then(|e| find_inner_block(e, working_set, cursor)),
+        Expr::Block(block_id) => Some(block_id),
+        Expr::Closure(block_id) => Some(block_id),
+        _ => None,
+    }
+}
+
+fn parse_expr(working_set: &StateWorkingSet, expr: &Expression, span: Span) -> Record {
+    match expr.expr {
+        Expr::RawString(ref raw_string) => record! {
+            "value" => Value::string(raw_string, span),
+            "type" => Value::string("raw_string", span),
+            "kind" => Value::string("string", span),
+        },
+        Expr::String(ref string) => record! {
+            "value" => Value::string(string, span),
+            "type" => Value::string("string", span),
+            "kind" => Value::string("string", span),
+        },
+        Expr::Int(int) => record! {
+            "value" => Value::int(int, span),
+            "type" => Value::string("int", span),
+            "kind" => Value::string("number", span),
+        },
+        Expr::Float(float) => record! {
+            "value" => Value::float(float, span),
+            "type" => Value::string("float", span),
+            "kind" => Value::string("number", span),
+        },
+        Expr::Directory(ref path, quoted) => record! {
+            "value" => Value::record(
+                record! {
+                    "path" => Value::string(path, span),
+                    "quoted" => Value::bool(quoted, span),
+                },
+                span,
+            ),
+            "type" => Value::string("directory", span),
+            "kind" => Value::string("path", span),
+        },
+        Expr::Filepath(ref path, quoted) => record! {
+            "value" => Value::record(
+                record! {
+                    "path" => Value::string(path, span),
+                    "quoted" => Value::bool(quoted, span),
+                },
+                span,
+            ),
+            "type" => Value::string("filepath", span),
+            "kind" => Value::string("path", span),
+        },
+        // TODO: support more types of expressions (e.g. glob patterns, cell path, and variables)
+        _ => {
+            let contents = working_set.get_span_contents(expr.span);
+            let str = String::from_utf8_lossy(contents).to_string();
+            record! {
+                "value" => Value::string(str, span),
+                "type" => Value::string("expression", span),
+                "kind" => Value::string("unknown", span),
+            }
+        }
+    }
+}
+
+fn is_cursor_in_call(call: &ast::Call, cursor: usize, working_set: &StateWorkingSet) -> bool {
+    let span = call.span();
+    return span.contains(cursor)
+        || working_set
+            .get_span_contents(Span::new(span.end, cursor + 1))
+            .iter()
+            .all(|b| b.is_ascii_whitespace());
+}
+
+#[cfg(test)]
+mod test {
+    #[test]
+    fn test_examples() -> nu_test_support::Result {
+        use super::AstCommand;
+        nu_test_support::test().examples(AstCommand)
+    }
+}
